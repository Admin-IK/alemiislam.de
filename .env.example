# Gebetszeiten (IGMG API) – echte Werte in .env.local (wird nicht committed)
PRAYER_TIMES_API_KEY=

# Optional – falls die API nur Header oder nur Query akzeptiert:
# PRAYER_TIMES_API_USE_QUERY=1
# PRAYER_TIMES_API_USE_HEADER=1
# PRAYER_TIMES_API_USE_BEARER=0
# PRAYER_TIMES_API_QUERY_PARAM=apiKey
# PRAYER_TIMES_API_HEADER=X-Api-Key
# PRAYER_TIMES_API_BASE=https://www.live.igmgapp.org:8091
# PRAYER_CITY_ID=20133

# EasyVerein API Token (Bearer)
# Generieren unter: https://easyverein.com/app/settings/easyVereinApi/
EASYVEREIN_API_TOKEN=

# Admin Dashboard Passwort
ADMIN_PASSWORD=
